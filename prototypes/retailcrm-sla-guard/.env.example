# Single-account pilot mode
RETAILCRM_URL=https://your-account.retailcrm.pro
RETAILCRM_API_KEY=replace-me
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_CHAT_ID=replace-me

# status:minutes,status:minutes
SLA_RULES=new:30,assembling:120,delivery:1440
POLL_INTERVAL_SECONDS=300
STATE_FILE=data/state.json
DRY_RUN=false

# Marketplace mode
PUBLIC_BASE_URL=https://guard.example.com
MARKETPLACE_SECRET=replace-with-partner-cabinet-secret
MARKETPLACE_MODULE_CODE=retailcrm-sla-guard
PORT=8080
TENANTS_FILE=data/tenants.json
AUDIT_LOG_FILE=data/audit.log
RETAILCRM_DOMAINS_URL=https://infra-data.retailcrm.tech/crm-domains.json
